{
  "name": "@sjhennig/claude-scaffold",
  "version": "1.1.0",
  "description": "Scaffold guardrailed, AI-first projects for Claude Code: devcontainer, five-layer guardrails, QC review plugin, and a starter context network in one command",
  "type": "module",
  "bin": {
    "claude-scaffold": "./bin/claude-scaffold.js"
  },
  "files": [
    "bin/",
    "src/",
    "!src/**/*.test.js"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "claude-code",
    "scaffold",
    "guardrails",
    "devcontainer",
    "ai-first",
    "project-generator"
  ],
  "homepage": "https://github.com/sjhennig/claude-scaffold#readme",
  "bugs": {
    "url": "https://github.com/sjhennig/claude-scaffold/issues"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:boot": "node scripts/boot-test.mjs",
    "test:agent-smoke": "node scripts/agent-smoke.mjs",
    "test:pack": "node scripts/pack-test.mjs",
    "test:firewall-boot": "node scripts/firewall-boot-test.mjs",
    "test:plugin-install": "node scripts/plugin-install-test.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "lint:shell": "node scripts/lint-shell.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify": "npm run format:check && npm run lint && npm test"
  },
  "dependencies": {
    "inquirer": "^9.2.12"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/sjhennig/claude-scaffold.git"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^9.0.0",
    "globals": "^16.0.0",
    "prettier": "^3.8.1",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "vite": "^8.0.5",
    "postcss": "^8.5.10",
    "picomatch": "^4.0.4"
  }
}
